<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{4D3C6CF7-D778-4A7F-90AB-F73E95C4956B}</ProjectGuid>
    <MainSource>activex_ai.dpr</MainSource>
    <ProjectVersion>20.0</ProjectVersion>
    <FrameworkType>None</FrameworkType>
    <Base>True</Base>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <TargetedPlatforms>3</TargetedPlatforms>
    <AppType>Library</AppType>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug'">
    <Cfg_1>true</Cfg_1>
    <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
    <DCC_DebugInformation>true</DCC_DebugInformation>
    <DCC_LocalDebugSymbols>true</DCC_LocalDebugSymbols>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release'">
    <Cfg_2>true</Cfg_2>
    <DCC_DebugInformation>false</DCC_DebugInformation>
    <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
    <DCC_Optimize>true</DCC_Optimize>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Platform)'=='Win32'">
    <DCC_ExeOutput>..\bin\Win32\$(Config)</DCC_ExeOutput>
    <DCC_DcuOutput>..\dcu32\$(Config)</DCC_DcuOutput>
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;Vcl;Vcl.Imaging;$(DCC_Namespace)</DCC_Namespace>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Platform)'=='Win64'">
    <DCC_ExeOutput>..\bin\Win64\$(Config)</DCC_ExeOutput>
    <DCC_DcuOutput>..\dcu64\$(Config)</DCC_DcuOutput>
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;Vcl;Vcl.Imaging;$(DCC_Namespace)</DCC_Namespace>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="activex_ai.dpr">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
    <DCCReference Include="activex_ai_TLB.pas" />
    <DCCReference Include="rpaiactivexcontrol.pas" />
    <DCCReference Include="rpaxaiimp.pas" />
    <RidlCompile Include="activex_ai.ridl" />
    <RcCompile Include="activex_ai_loader.rc" />
  </ItemGroup>
  <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')" />
</Project>