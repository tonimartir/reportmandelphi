<NAME type="String">TRPDATAINFOITEM1</NAME>
<DATABASEALIAS type="String">DEBUGEXAMPLE</DATABASEALIAS>
<SQL type="WideString">SELECT#13##10#    C.CUSTOMERID AS #34#Cli
ente_ID#34##44##13##10#    C.CUSTOMERNAME
 AS #34#Nombre_Cliente#34##44##13##10#   
 SUM(S.TOTALAMOUNT) AS #34#Total_Ventas#34#
#13##10#FROM#13##10#    #34#SALES#34# S#13#
#10#JOIN#13##10#    #34#CUSTOMERS#34# C#13#
#10#    ON S.CUSTOMERID = C.CUSTOMERID#13#
#10#GROUP BY#13##10#    C.CUSTOMERID#44##13#
#10#    C.CUSTOMERNAME#13##10#ORDER BY#13#
#10#    #34#Total_Ventas#34# DESC</SQL>
