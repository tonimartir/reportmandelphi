        'OM'#13#10'    "SALES" S'#13#10'JOIN'#13#10'    "CUSTOMERS" C'#13#10'    ON S.CUSTOMERID ' +
        '= C.CUSTOMERID'#13#10'GROUP BY'#13#10'    C.CUSTOMERID,'#13#10'    C.CUSTOMERNAME'#13 +
        #10'ORDER BY'#13#10'    "Total_Ventas" DESC'
